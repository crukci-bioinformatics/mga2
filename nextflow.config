
manifest {
    name = 'crukci-bioinformatics/mga2'
    author = 'Matt Eldridge'
    homePage = 'https://github.com/crukci-bioinformatics/mga2'
    description = 'Multi-Genome Alignment (MGA) contaminant screen for genomic sequencing data'
    mainScript = 'mga2.nf'
    nextflowVersion = '>=25.10.0'
    version = '2.1.0-snapshot'
}

params {
    showSettings          = true
    help                  = false
    sampleSheet           = "samplesheet.csv"
    fastqDir              = ""
    sampleSize            = 100000
    maxNumberToSampleFrom = Long.MAX_VALUE
    chunkSize             = 1000000
    trimStart             = 1
    trimLength            = 36
    genomeDetails         = "${projectDir}/resources/genomes.csv"
    bowtieIndexDir        = "bowtie_indexes"
    adaptersFasta         = "${projectDir}/resources/adapters.fa"
    outputDir             = "${launchDir}"
    outputPrefix          = "mga_"
}

process {
    container = { "crukcibioinformatics/mga2:${workflow.manifest.version.endsWith('-snapshot') ? 'latest' : workflow.manifest.version}" }

    errorStrategy = {
        task.exitStatus in [ 104, 134, 137, 138, 139, 140 ] ? 'retry' : 'finish'
    }

    cpus = 1
    memory = 1.GB
    time = 1.h
}

singularity {
    autoMounts = true
    runOptions = "--no-home"
}

profiles {
    standard {
        process.executor = 'local'
        process.resourceLimits = [ cpus: 4, memory: 16.GB ]
        executor {
            cpus = 4
            memory = 16.GB
        }
    }

    bigserver {
        process.executor = 'local'
        process.resourceLimits = [ cpus: 30, memory: 128.GB ]
        executor {
            cpus = 30
            memory = 128.GB
        }
    }

    cluster {
        process.executor = 'slurm'
        // adjust to the limits of the largest usable partition on your cluster
        process.resourceLimits = [ cpus: 64, memory: 256.GB, time: 24.h ]
        executor {
            queueSize = 50
            pollInterval = 30.s
            jobName = { "'$task.name'" }
        }
        singularity.enabled = true
    }
}

